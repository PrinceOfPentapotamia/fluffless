{
  "manifest_version": 3,
  "name": "Fluffless",
  "version": "1.0",
  "description": "Stop the fluff. Get the facts. Instantly debunk clickbait YouTube videos.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ]
}
